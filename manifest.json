{
  "manifest_version": 3,
  "name": "De-Slop LinkedIn",
  "version": "1.0",
  "description": "Rescue your feed from boring corporate AI-slop! Rewrite posts into Shakespeare, Harry Potter, Pirate, Yoda, and more.",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.svg",
      "48": "icon.svg",
      "128": "icon.svg"
    }
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
